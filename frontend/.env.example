# ── AFianco Frontend — Environment Template ──────────────────────────────────
#
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# IMPORTANT: variables MUST be prefixed with REACT_APP_ to be visible to the
# React app. CRA only injects vars matching that prefix into process.env at
# build time. The other vars below (WDS_SOCKET_PORT, ENABLE_HEALTH_CHECK)
# are dev-server-only and read by craco.config.js / scripts.

# ── Backend connection ───────────────────────────────────────────────────────
# Backend API base URL. Used by axios clients in src/api/.
# Dev: http://localhost:8000
# Prod: https://app.afianco.app (set on the server in .env, never commit)
REACT_APP_BACKEND_URL=http://localhost:8000

# ── Dev-only ─────────────────────────────────────────────────────────────────
# Webpack dev server socket port. Set to 443 if running behind nginx with TLS.
WDS_SOCKET_PORT=443

# Health check endpoint plugin (dev-only diagnostic, see craco.config.js).
# Production builds ignore this.
ENABLE_HEALTH_CHECK=false

# ── Observability (Phase 1 — Step A2) ────────────────────────────────────────
# Sentry SDK — error tracking + performance monitoring (frontend).
# Get DSN at: https://sentry.io → afianco-frontend project → Client Keys (DSN)
# OPTIONAL — if unset, Sentry is fully disabled (noop). The app boots and
# runs identically; no events captured, no outbound calls, zero overhead.
REACT_APP_SENTRY_DSN=

# Percentage of pageloads to trace for performance monitoring (0.0–1.0).
# OPTIONAL — defaults to 0.1 (10%). Lower if you hit free-tier quota.
REACT_APP_SENTRY_TRACES_RATE=0.1

# Environment tag for Sentry events (overrides NODE_ENV if set).
# OPTIONAL — defaults to NODE_ENV ("development" / "production").
REACT_APP_SENTRY_ENVIRONMENT=

# Git SHA of the deployed release. Used for release tracking in Sentry.
# OPTIONAL — defaults to "unknown".
# Set in deploy script: REACT_APP_RELEASE_SHA=$(git rev-parse --short HEAD)
REACT_APP_RELEASE_SHA=
