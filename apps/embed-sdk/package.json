{
  "name": "@afianco/embed-sdk",
  "version": "0.1.0",
  "description": "Embed SDK — Web Components per merchant cross-origin embed (Stream A).",
  "private": true,
  "type": "module",
  "main": "./dist/afianco-embed.umd.js",
  "module": "./dist/afianco-embed.es.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/afianco-embed.es.js",
      "require": "./dist/afianco-embed.umd.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "lit": "^3.2.0",
    "@lit/context": "^1.1.3",
    "@afianco/api-client": "workspace:*",
    "@afianco/design-tokens": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "vite": "^5.4.0",
    "vitest": "^2.0.0",
    "@types/node": "^20.12.0",
    "happy-dom": "^15.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
