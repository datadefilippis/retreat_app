        {
          "expr": "histogram_quantile(0.95, sum by (le, endpoint) (rate(api_response_time_seconds_bucket[5m])))",
          "refId": "B",
          "legendFormat": "p95 {{endpoint}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, endpoint) (rate(api_response_time_seconds_bucket[5m])))",
