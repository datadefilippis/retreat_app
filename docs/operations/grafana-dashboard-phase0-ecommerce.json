      "type": "timeseries",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 5},
          "unit": "s"
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, endpoint) (rate(api_response_time_seconds_bucket[5m])))",
          "refId": "A",
          "legendFormat": "p50 {{endpoint}}"
