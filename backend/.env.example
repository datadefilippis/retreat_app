# ── Retreat App Backend — Environment Template ───────────────────────────────
#
# Copy this file to `.env` and fill in the real values.
# NEVER commit the actual `.env` file — it is gitignored.
# REGOLA DEL FORK: nessun valore può essere riusato da AFianco/BI_PMI.
#
# Generate strong secrets with:
#   openssl rand -hex 32

# ── Database ─────────────────────────────────────────────────────────────────
MONGO_URL="mongodb://localhost:27017"
DB_NAME="retreat_dev"

# ── CORS ─────────────────────────────────────────────────────────────────────
# Dev: "*" allows any origin (falls back to localhost:3000/3001 anyway)
# Prod: comma-separated list of our domains only.
CORS_ORIGINS="*"

# ── Runtime ──────────────────────────────────────────────────────────────────
ENVIRONMENT="development"

# ── Authentication ───────────────────────────────────────────────────────────
# MUST be a 64-char hex string. Server will refuse to start if missing.
# Rotating this invalidates every outstanding JWT — users will be logged out.
JWT_SECRET_KEY="REPLACE_ME_WITH_OUTPUT_OF_openssl_rand_hex_32"

# ── LLM provider ─────────────────────────────────────────────────────────────
# Il modulo AI è DISATTIVATO nei piani retreat (kill-list, Fase 1.3 del
# master plan). Lasciare vuoto salvo decisione scritta nel piano.

# ── Stripe ───────────────────────────────────────────────────────────────────
# Account Stripe DEDICATO Retreat App (mai quello AFianco).
# Use test keys (sk_test_*, pk_test_*) in dev.
# Production keys live in the production env only, never here.
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Legacy (non più usato dal flusso Connect post-Block 6) — lasciare vuoto.
STRIPE_CLIENT_ID=""

# ── Email (Brevo) ────────────────────────────────────────────────────────────
# Account/sender Brevo DEDICATO Retreat App.
# If unset, email sending falls back to dry-run (log-only).
BREVO_API_KEY=""
SMTP_FROM_EMAIL="noreply@example.com"
# Nome brand definitivo da decidere (candidati: Ritirando / Ritiri in Italia)
SMTP_FROM_NAME="Retreat App"

# ── App URLs ─────────────────────────────────────────────────────────────────
# Two distinct vars — see backend/services/url_builder.py for the rationale.
#
#   PUBLIC_APP_URL — used in customer-facing post-purchase email links
#                    (/t/<token>, /b/<token>, /rsv/<token>, /d/<token>,
#                    /account/courses/...). Recipients are often on
#                    devices that won't ever reach an internal hostname.
#   APP_URL        — used in admin / authenticated flows (verify-email,
#                    reset-password, /account/orders/...).
#
# In dev both point at the CRA frontend (:3000). In prod both should be
# the public domain of the new brand. The dual setting lets infrastructure
# split them later without a code migration.
FRONTEND_URL="http://localhost:3000"
APP_URL="http://localhost:3000"
PUBLIC_APP_URL="http://localhost:3000"

# ── Observability ────────────────────────────────────────────────────────────
# Sentry SDK — error tracking + performance monitoring.
# OPTIONAL — if unset, Sentry is fully disabled (noop). Se attivato, creare
# un progetto Sentry NUOVO dedicato (non quello AFianco).
SENTRY_DSN=""

# Percentage of requests to trace (0.0–1.0). OPTIONAL — smart default per env
# (production 0.0001 / staging 0.01 / development 0.1). Gli errori sono sempre
# catturati al 100%.
# SENTRY_TRACES_RATE=""

# Git SHA of the deployed release (set by deploy script). OPTIONAL.
RELEASE_SHA=""

# ── Logging ──────────────────────────────────────────────────────────────────
# LOG_FORMAT: text (dev) | json (prod, per ingestione Loki/ELK). Default text.
LOG_FORMAT="text"
# LOG_LEVEL: DEBUG / INFO / WARNING / ERROR / CRITICAL. Default INFO.
LOG_LEVEL="INFO"

# ── Backup alerts ────────────────────────────────────────────────────────────
# Where deploy/backup.sh sends email when a nightly backup fails.
# OPTIONAL — if unset, the backup script logs the failure but no email leaves.
BACKUP_ALERT_EMAIL=""

# ── Brevo webhook ────────────────────────────────────────────────────────────
# Shared secret for the Brevo bounce/complaint webhook. Configured both here
# AND in Brevo dashboard (custom header "X-Webhook-Secret"). Default-deny if
# unset (endpoint returns 503). Generate with: openssl rand -hex 32
BREVO_WEBHOOK_SECRET=""

# ── /metrics endpoint authentication ─────────────────────────────────────────
# Token required to GET /metrics in production/staging (fail-closed if unset).
# Dev: unset → no auth. Generate with: openssl rand -hex 32
METRICS_AUTH_TOKEN=""
