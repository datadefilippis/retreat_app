# ── AFianco Backend — Environment Template ───────────────────────────────────
#
# Copy this file to `.env` and fill in the real values.
# NEVER commit the actual `.env` file — it is gitignored.
#
# Generate a strong JWT secret with:
#   openssl rand -hex 32

# ── Database ─────────────────────────────────────────────────────────────────
MONGO_URL="mongodb://localhost:27017"
DB_NAME="test_database"

# ── CORS ─────────────────────────────────────────────────────────────────────
# Dev: "*" allows any origin (falls back to localhost:3000/3001 anyway)
# Prod: comma-separated list, e.g. "https://app.afianco.ch,https://afianco.ch"
CORS_ORIGINS="*"

# ── Runtime ──────────────────────────────────────────────────────────────────
ENVIRONMENT="development"

# ── Authentication ───────────────────────────────────────────────────────────
# MUST be a 64-char hex string. Server will refuse to start if missing.
# Rotating this invalidates every outstanding JWT — users will be logged out.
JWT_SECRET_KEY="REPLACE_ME_WITH_OUTPUT_OF_openssl_rand_hex_32"

# ── LLM provider ─────────────────────────────────────────────────────────────
# Anthropic Claude is the active LLM for AI chat and digest features.
ANTHROPIC_API_KEY=""

# ── Stripe ───────────────────────────────────────────────────────────────────
# Use test keys (sk_test_*, pk_test_*) in dev.
# Production keys live in your production secret manager, never here.
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_CLIENT_ID=""

# ── Email (Brevo) ────────────────────────────────────────────────────────────
# If unset, email sending falls back to dry-run (log-only).
BREVO_API_KEY=""
SMTP_FROM_EMAIL="noreply@example.com"
SMTP_FROM_NAME="AFianco"

# ── App URLs ─────────────────────────────────────────────────────────────────
# Two distinct vars — see backend/services/url_builder.py for the rationale.
#
#   PUBLIC_APP_URL — used in customer-facing post-purchase email links
#                    (/t/<token>, /b/<token>, /rsv/<token>, /d/<token>,
#                    /account/courses/...). Recipients are often on
#                    devices that won't ever reach an internal hostname.
#   APP_URL        — used in admin / authenticated flows (verify-email,
#                    reset-password, /account/orders/...).
#
# In dev both point at the CRA frontend (:3000). In prod both should be
# the public domain (e.g. https://afianco.app). The dual setting lets
# infrastructure split them later without a code migration.
FRONTEND_URL="http://localhost:3000"
APP_URL="http://localhost:3000"
PUBLIC_APP_URL="http://localhost:3000"

# ── Observability (Phase 1 — Step A1) ────────────────────────────────────────
# Sentry SDK — error tracking + performance monitoring.
# Get DSN at: https://sentry.io → project settings → Client Keys (DSN)
# OPTIONAL — if unset, Sentry is fully disabled (noop). The app boots and
# runs identically; no events captured, no outbound calls, zero overhead.
SENTRY_DSN=""

# Percentage of requests to trace for performance monitoring (0.0–1.0).
# OPTIONAL — env-based smart default (Track O Step 1.2):
#   production:  0.0001 (0.01%) → ~13k traces/mese a 50 req/s, sotto
#                  Sentry Developer free tier quota (10k transactions/mese)
#   staging:     0.01 (1%)
#   development: 0.1 (10%)
# Override esplicito qui SOLO per emergency tuning prod senza redeploy.
# Errori sono SEMPRE 100% catturati (counter separato, no throttle).
# SENTRY_TRACES_RATE=""

# Git SHA of the deployed release. Used for release tracking in Sentry.
# OPTIONAL — defaults to "unknown".
# Set in deploy script: RELEASE_SHA=$(git rev-parse --short HEAD)
RELEASE_SHA=""

# ── Logging (Phase 1 — Step A3) ──────────────────────────────────────────────
# Output format for application logs:
#   text — plain "[cid=...] - message" lines (backward compat, easy to read in
#          tail -f). Default in development.
#   json — one JSON object per line with ts, level, logger, request_id,
#          user_id, org_id, msg. Recommended for production (Loki / Datadog /
#          ELK ingestion).
# OPTIONAL — defaults to "text".
LOG_FORMAT="text"

# Log level threshold — DEBUG / INFO / WARNING / ERROR / CRITICAL.
# OPTIONAL — defaults to INFO.
LOG_LEVEL="INFO"

# ── Backup alerts (Phase 1 Step C3) ──────────────────────────────────────────
# Where deploy/backup.sh sends email when a nightly backup fails.
# OPTIONAL — if unset, the backup script logs the failure but no email leaves.
# Reuses BREVO_API_KEY + SMTP_FROM_EMAIL (already configured in production).
# This var is consumed by deploy/backup.sh on the server (not by the Python
# backend), but kept here for documentation and to avoid env drift.
BACKUP_ALERT_EMAIL="davidedefilippis94@gmail.com"

# ── Brevo webhook (Phase 1 Step B2) ──────────────────────────────────────────
# Shared secret for the Brevo bounce/complaint webhook. Configured both here
# AND in Brevo dashboard (Settings → Webhooks → Custom header named
# "X-Webhook-Secret"). The endpoint /api/webhooks/brevo refuses requests
# whose header doesn't match this value (default-deny if unset).
# Generate with:  openssl rand -hex 32
# OPTIONAL — when unset the endpoint returns 503 (default-deny). Set this
# AND configure the Brevo webhook to enable bounce tracking.
BREVO_WEBHOOK_SECRET=""

# ── Track S Step 4.1 — /metrics endpoint authentication ──────────────────
#
# Token required to GET /metrics (Prometheus exposition) when
# ENVIRONMENT=production or staging. In dev unset → no auth (convenience
# for Prometheus / Grafana Agent running locally).
#
# Caller passes:  curl -H "X-Metrics-Token: <value>" .../metrics
# Mismatch → 401 Unauthorized.
# Env unset in prod → 503 Service Unavailable (fail-closed default-deny).
#
# Generate with:  openssl rand -hex 32
# Rotate via:     update env var + restart Prometheus scraper config
METRICS_AUTH_TOKEN=""
