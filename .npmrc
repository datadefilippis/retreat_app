# pnpm config — Phase 0 Step 6 (2026-05-28)

# Strict peer dependencies: warn but don't fail on peer mismatches.
# Necessary because some old deps in the ecosystem have peer issues we
# can't fix unilaterally.
strict-peer-dependencies=false

# Auto-install peer dependencies (npm 7+ default behaviour)
auto-install-peers=true

# Hoist patterns — flatten common deps to root for compat with tools
# that don't understand nested pnpm structure (eslint, prettier, vite).
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=@types/*
public-hoist-pattern[]=vite*

# Engine strictness: enforce Node version declared in package.json
engine-strict=true

# pnpm 9+ asks for explicit approval of postinstall scripts. We pre-approve
# esbuild because Vite depends on it and its postinstall just downloads the
# platform binary — required for vite build to work.
# (Approved-builds list lives in pnpm-workspace.yaml's onlyBuiltDependencies.)
