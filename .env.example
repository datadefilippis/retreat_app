# ══════════════════════════════════════════════════════════════════
#  Margin Sentinel AI — Environment Variables
# ══════════════════════════════════════════════════════════════════
#
#  Copy this file to .env.production and fill in real values:
#    cp .env.example .env.production
#
#  Then launch with:
#    docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build
#
# ──────────────────────────────────────────────────────────────────

# ── ENVIRONMENT ──────────────────────────────────────────────────
# "production" disables demo data seeding and dev-only features.
# MANDATORY — never leave this as "development" on a real server.
ENVIRONMENT=production

# ── DATABASE ─────────────────────────────────────────────────────
# MongoDB root credentials (used by MONGO_INITDB in the mongo container).
# The backend connects via these creds + authSource=admin.
# MANDATORY — choose strong, unique values.
MONGO_ROOT_USER=margin_admin
MONGO_ROOT_PASSWORD=CHANGE_ME_strong_random_password_here

# Database name for the application. One DB per environment.
DB_NAME=margin_sentinel_prod

# ── AUTHENTICATION ───────────────────────────────────────────────
# JWT signing key. The backend REFUSES to start without this.
# Generate with: openssl rand -hex 32
# MANDATORY — MUST be unique, random, at least 32 hex chars.
JWT_SECRET_KEY=CHANGE_ME_run_openssl_rand_hex_32

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# MANDATORY — set to your actual domain(s) with https://.
# Example: https://app.tuodominio.it
# Multiple: https://app.tuodominio.it,https://staging.tuodominio.it
CORS_ORIGINS=https://YOUR_DOMAIN

# ── AI / LLM ────────────────────────────────────────────────────
# Anthropic Claude API key — powers all AI features:
# health explanation, smart alerts, chat, digest.
# OPTIONAL — if not set, AI falls back to rule-based responses.
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── BACKGROUND JOBS ─────────────────────────────────────────────
# How often (hours) to run automatic alert checks for all orgs.
# OPTIONAL — defaults to 6.
BACKGROUND_ALERT_INTERVAL_HOURS=6

# Seconds to wait after startup before the first background tick.
# OPTIONAL — defaults to 60 in production (30 in dev).
BACKGROUND_INITIAL_DELAY_SECONDS=60

# ── AWS S3 (optional file backup) ───────────────────────────────
# If set, uploaded CSV/XLSX files are also copied to S3.
# If not set, files are stored only in the local uploads/ volume.
# OPTIONAL — all four must be set together for S3 to activate.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
AWS_REGION=eu-west-1

# ── EMAIL (Brevo API) ─────────────────────────────────────────
# Brevo (ex Sendinblue) API key for transactional emails
# (password reset, welcome, notifications).
# Free tier: 300 email/day.
# Get your key at: https://app.brevo.com → Settings → SMTP & API → API Keys
# OPTIONAL — if not set, emails are logged but not sent.
BREVO_API_KEY=
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=AFianco
APP_URL=https://YOUR_DOMAIN

# ── STRIPE (Billing v5.0) ──────────────────────────────
# Stripe API keys.  Start with TEST mode keys (sk_test_ / pk_test_),
# swap to LIVE keys (sk_live_ / pk_live_) for production billing.
# Get keys at: https://dashboard.stripe.com/apikeys
# OPTIONAL — if STRIPE_SECRET_KEY is not set, billing features are
# disabled (billingEnabled=false in /api/billing/config).
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Stripe webhook signing secret.
# Each webhook endpoint (test vs live) has its own whsec_ secret.
# Get from: Stripe Dashboard → Developers → Webhooks → endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=

# Frontend URL for Stripe redirect callbacks.
# Used by checkout success/cancel and customer portal return URLs.
# MUST include https:// and match the actual user-facing domain.
# Example: https://app.afianco.it
FRONTEND_URL=https://YOUR_DOMAIN
