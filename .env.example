# ══════════════════════════════════════════════════════════════════
#  Retreat App — Production Environment Variables
# ══════════════════════════════════════════════════════════════════
#
#  Copy this file to .env.production and fill in real values:
#    cp .env.example .env.production
#
#  Then launch with:
#    docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build
#
#  REGOLA DEL FORK: ogni valore è NUOVO e dedicato a Retreat App.
#  Nessun segreto, account o risorsa può essere riusato da AFianco.
# ──────────────────────────────────────────────────────────────────

# ── ENVIRONMENT ──────────────────────────────────────────────────
# "production" disables demo data seeding and dev-only features.
# MANDATORY — never leave this as "development" on a real server.
ENVIRONMENT=production

# ── DATABASE ─────────────────────────────────────────────────────
# MongoDB root credentials (used by MONGO_INITDB in the mongo container).
# MANDATORY — choose strong, unique values (openssl rand -hex 24).
MONGO_ROOT_USER=retreat_admin
MONGO_ROOT_PASSWORD=CHANGE_ME_strong_random_password_here

# Database name for the application. One DB per environment.
DB_NAME=retreat_prod

# ── AUTHENTICATION ───────────────────────────────────────────────
# JWT signing key. The backend REFUSES to start without this.
# Generate with: openssl rand -hex 32
# MANDATORY — unique to Retreat App, never the AFianco one.
JWT_SECRET_KEY=CHANGE_ME_run_openssl_rand_hex_32

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (https:// + our domains only).
CORS_ORIGINS=https://YOUR_DOMAIN

# ── AI / LLM ────────────────────────────────────────────────────
# Modulo AI DISATTIVATO nei piani retreat (kill-list). Lasciare vuoto.
ANTHROPIC_API_KEY=

# ── BACKGROUND JOBS ─────────────────────────────────────────────
# OPTIONAL — defaults: interval 6h, initial delay 60s (prod).
BACKGROUND_ALERT_INTERVAL_HOURS=6
BACKGROUND_INITIAL_DELAY_SECONDS=60

# ── AWS S3 (optional file backup) ───────────────────────────────
# If set, uploaded files are also copied to S3 (bucket dedicato).
# OPTIONAL — all four must be set together for S3 to activate.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
AWS_REGION=eu-west-1

# ── EMAIL (Brevo API) ─────────────────────────────────────────
# Account Brevo DEDICATO, sender del nuovo dominio (SPF/DKIM verificati).
# OPTIONAL — if not set, emails are logged but not sent.
BREVO_API_KEY=
SMTP_FROM_EMAIL=noreply@YOUR_DOMAIN
SMTP_FROM_NAME=Retreat App
APP_URL=https://YOUR_DOMAIN
PUBLIC_APP_URL=https://YOUR_DOMAIN

# Brevo bounce/complaint webhook shared secret (openssl rand -hex 32).
BREVO_WEBHOOK_SECRET=

# ── STRIPE ──────────────────────────────────────────────────────
# Account Stripe piattaforma DEDICATO Retreat App (Connect Express).
# Start with TEST keys (sk_test_/pk_test_), swap to LIVE for launch.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Stripe webhook signing secret (per-endpoint, whsec_*).
STRIPE_WEBHOOK_SECRET=

# Frontend URL for Stripe redirect callbacks (checkout success/cancel).
# MUST include https:// and match the actual user-facing domain.
FRONTEND_URL=https://YOUR_DOMAIN

# ── OBSERVABILITY ───────────────────────────────────────────────
# Sentry (progetto nuovo dedicato). OPTIONAL — unset = disabled.
SENTRY_DSN=
RELEASE_SHA=
LOG_FORMAT=json
LOG_LEVEL=INFO

# ── BACKUP ──────────────────────────────────────────────────────
# Alert email when nightly backup fails (deploy/backup.sh).
BACKUP_ALERT_EMAIL=

# ── /metrics auth (fail-closed in prod) ─────────────────────────
METRICS_AUTH_TOKEN=
